# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it is in .gitignore.

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Which AI provider to use for generating responses.
# Valid values: "gemini" | "openai" | "perplexity"
AI_PROVIDER=gemini

# Your Gemini API key — required if AI_PROVIDER=gemini
# Get it here → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Your OpenAI API key — required if AI_PROVIDER=openai
# Get it here → https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# Your Perplexity API key — required if AI_PROVIDER=perplexity
# Get it here → https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_key_here

# Your xAI (Grok) API key — required if using xAI as provider
# Get it here → https://console.x.ai/
XAI_API_KEY=your_key_here

# ─── Dev.to ───────────────────────────────────────────────────────────────────
# API key for posting articles to Dev.to
# Get it here → https://dev.to/settings/extensions (scroll to "DEV Community API Keys")
DEVTO_API_KEY=test

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Your MongoDB connection string (from MongoDB Atlas or local Compass)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
# Get it here → https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI = your_compass_account_url

# ─── Twilio (SMS / Voice) ─────────────────────────────────────────────────────
# Used for sending SMS notifications or voice calls via Twilio.
# Sign up → https://www.twilio.com/try-twilio
# Find SID and Auth Token in your Twilio Console → https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# The Twilio phone number you purchased (must be SMS-capable)
# Format: +1XXXXXXXXXX
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Your own phone number for local testing of Twilio SMS/calls
# Format: +91XXXXXXXXXX (include country code)
TEST_PHONE_NUMBER=your_personal_phone_number_for_testing

# ─── ElevenLabs (Text-to-Speech) ──────────────────────────────────────────────
# API key for generating AI voice audio via ElevenLabs
# Get it here → https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ─── Social Sharing ───────────────────────────────────────────────────────────
# Twitter / X API credentials — needed for posting tweets
# Apply for access → https://developer.twitter.com/en/portal/dashboard
# Create an app → get Keys and Tokens under your app's settings
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:your_urn_here